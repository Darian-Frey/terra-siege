# Test fixture — cube authored with quads instead of triangles.
# Loader should triangulate each quad to 2 tris (T-02).
o cube_quads

v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0

usemtl c01
# Six quad faces — each triangulates to 2 tris (12 total).
f 1 4 3 2
f 5 6 7 8
f 1 5 8 4
f 2 3 7 6
f 1 2 6 5
f 4 8 7 3
