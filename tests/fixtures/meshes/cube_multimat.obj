# Test fixture — cube with two materials (T-03 verifies usemtl tracking).
# Top face is c11 (orange), everything else is c08 (mid grey).
o cube_multimat

v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0

usemtl c08
# Five faces with c08
f 1 3 2
f 1 4 3
f 5 6 7
f 5 7 8
f 1 8 4
f 1 5 8
f 2 3 7
f 2 7 6
f 1 2 6
f 1 6 5

usemtl c11
# Top face (+Y) with c11
f 4 8 7
f 4 7 3
