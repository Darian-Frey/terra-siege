# Test fixture — canonical cube. 8 verts, 12 triangles, single material.
o cube

v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0
v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0

usemtl c01
# back face (-Z)
f 1 3 2
f 1 4 3
# front face (+Z)
f 5 6 7
f 5 7 8
# left face (-X)
f 1 8 4
f 1 5 8
# right face (+X)
f 2 3 7
f 2 7 6
# bottom face (-Y)
f 1 2 6
f 1 6 5
# top face (+Y)
f 4 8 7
f 4 7 3
