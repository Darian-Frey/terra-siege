# terra-siege repair station — heal-pad friendly structure.
# Base + glow-pad + yellow cross (two thin bars). 32 verts.
# Local frame: +Z forward. c13 base + c31 pad + c17 cross.
o repair_station

# Base 5.0 × 0.8 × 5.0 at (0, 0.2, 0) — sits flush on terrain
v -2.5 -0.2 -2.5
v  2.5 -0.2 -2.5
v  2.5  0.6 -2.5
v -2.5  0.6 -2.5
v -2.5 -0.2  2.5
v  2.5 -0.2  2.5
v  2.5  0.6  2.5
v -2.5  0.6  2.5

# Glow pad 3.5 × 0.2 × 3.5 at (0, 0.5, 0)
v -1.75 0.4 -1.75
v  1.75 0.4 -1.75
v  1.75 0.6 -1.75
v -1.75 0.6 -1.75
v -1.75 0.4  1.75
v  1.75 0.4  1.75
v  1.75 0.6  1.75
v -1.75 0.6  1.75

# Cross bar A 1.8 × 0.1 × 0.4 at (0, 0.65, 0) — horizontal bar (along X)
v -0.9 0.6 -0.2
v  0.9 0.6 -0.2
v  0.9 0.7 -0.2
v -0.9 0.7 -0.2
v -0.9 0.6  0.2
v  0.9 0.6  0.2
v  0.9 0.7  0.2
v -0.9 0.7  0.2

# Cross bar B 0.4 × 0.1 × 1.8 at (0, 0.65, 0) — vertical bar (along Z)
v -0.2 0.6 -0.9
v  0.2 0.6 -0.9
v  0.2 0.7 -0.9
v -0.2 0.7 -0.9
v -0.2 0.6  0.9
v  0.2 0.6  0.9
v  0.2 0.7  0.9
v -0.2 0.7  0.9

