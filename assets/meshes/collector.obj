v -1.5 -0.7 -2.25
v  1.5 -0.7 -2.25
v  1.5  0.7 -2.25
v -1.5  0.7 -2.25
v -1.5 -0.7  2.25
v  1.5 -0.7  2.25
v  1.5  0.7  2.25
v -1.5  0.7  2.25

# Port tread 0.6 × 0.6 × 4.5 at (-1.8, -0.4, 0)
v -2.1 -0.7 -2.25
v -1.5 -0.7 -2.25
v -1.5 -0.1 -2.25
v -2.1 -0.1 -2.25
v -2.1 -0.7  2.25
v -1.5 -0.7  2.25
v -1.5 -0.1  2.25
v -2.1 -0.1  2.25

# Starboard tread 0.6 × 0.6 × 4.5 at (+1.8, -0.4, 0)
v  1.5 -0.7 -2.25
v  2.1 -0.7 -2.25
v  2.1 -0.1 -2.25
v  1.5 -0.1 -2.25
v  1.5 -0.7  2.25
v  2.1 -0.7  2.25
v  2.1 -0.1  2.25
v  1.5 -0.1  2.25

