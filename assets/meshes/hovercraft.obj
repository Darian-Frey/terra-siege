# terra-siege hovercraft — player ship.
#
# Diamond hull + cockpit dome. 11 unique vertices, 16 triangles.
# Local frame: +X right, +Y up, +Z forward (nose). Matches the game's
# yaw convention so DrawModelEx around world-up rotates correctly.
#
# Materials:
#   c15  light grey  — top hull
#   c30  structure grey — bottom hull
#   c10  sky blue    — cockpit dome
o hovercraft

# Hull verts
v 0.000000 0.050000 2.400000
v 0.000000 0.050000 -2.400000
v 1.800000 0.050000 0.000000
v -1.800000 0.050000 0.000000
v 0.000000 0.550000 0.000000
v 0.000000 -0.450000 0.000000

# Cockpit dome ring (y=0.67) + peak
v 0.000000 0.670000 0.420000
v 0.420000 0.670000 0.000000
v 0.000000 0.670000 -0.420000
v -0.420000 0.670000 0.000000
v 0.000000 0.970000 0.000000

# Top hull — four tris meeting at apex (v5)
usemtl c15
g hull_top
f 1 3 5
f 3 2 5
f 2 4 5
f 4 1 5

# Cockpit neck — apex to dome ring
g cockpit_neck
f 5 7 8
f 5 8 9
f 5 9 10
f 5 10 7

# Bottom hull — four tris meeting at belly (v6)
usemtl c30
g hull_bottom
f 1 6 3
f 3 6 2
f 2 6 4
f 4 6 1

# Cockpit dome — four tris meeting at peak (v11)
usemtl c10
g cockpit_dome
f 7 8 11
f 8 9 11
f 9 10 11
f 10 7 11
