v  0.6 -0.4  2.0
v  0.6  0.4  2.0
v -0.6  0.4  2.0
v -0.6 -0.4  3.2
v  0.6 -0.4  3.2
v  0.6  0.4  3.2
v -0.6  0.4  3.2

usemtl c16
