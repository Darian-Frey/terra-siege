v -1.5 -0.75 -2.0
v  1.5 -0.75 -2.0
v  1.5  0.75 -2.0
v -1.5  0.75 -2.0
v -1.5 -0.75  2.0
v  1.5 -0.75  2.0
v  1.5  0.75  2.0
v -1.5  0.75  2.0

# Nose tip 1.2 × 0.8 × 1.2 at (0, 0, 2.6) — in front along +Z
